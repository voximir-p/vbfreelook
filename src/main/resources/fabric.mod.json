{
  "schemaVersion": 1,
  "id": "vbfreelook",
  "version": "${version}",
  "name": "Voximir's Better Freelook",
  "description": "Lets you look around without changing your movement direction.",
  "authors": [
    "Voximir"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/vbfreelook",
    "sources": "https://github.com/voximir-p/vbfreelook"
  },
  "license": "MIT",
  "icon": "assets/vbfreelook/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "org.voximir.vbfreelook.VBFreelook"
    ],
    "modmenu": [
      "org.voximir.vbfreelook.config.ModMenuIntegration"
    ]
  },
  "mixins": [
    "vbfreelook.mixins.json"
  ],
  "depends": {
    "fabricloader": "${loader_version_range}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version_range}",
    "java": "${java_version_range}",
    "yet_another_config_lib_v3": "${yacl_version_range}"
  }
}
